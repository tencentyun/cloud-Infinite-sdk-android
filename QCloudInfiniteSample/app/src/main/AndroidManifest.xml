<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.tencent.qcloud.infinite.sample">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".ResponsiveActivity" android:label="自适应图片加载" />
        <activity android:name=".TpgActivity" android:label="TPG图片加载" />
        <activity android:name=".ThumbnailActivity" android:label="缩放"/>
        <activity android:name=".CropActivity" android:label="剪裁"/>
        <activity android:name=".RotateActivity" android:label="旋转"/>
        <activity android:name=".FormatActivity" android:label="格式转换"/>
        <activity android:name=".GifOptActivity" android:label="GIF优化"/>
        <activity android:name=".QualityActivity" android:label="质量调节"/>
        <activity android:name=".WatermarkActivity" android:label="水印"/>
        <activity android:name=".BlurActivity" android:label="高斯模糊"/>
        <activity android:name=".SharpenActivity" android:label="锐化"/>
        <activity android:name=".StripActivity" android:label="去除元信息"/>
        <activity android:name=".ImageAveActivity" android:label="图片主色" />
        <activity android:name=".GifActivity" android:label="TPG GIF"/>
    </application>

</manifest>